<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{displayName}} — Resume</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Karla:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>

  :root{
    --paper:      #F2EFE4;
    --paper-soft: #FAF9F3;
    --ink:        #232A1F;
    --ink-soft:   #565F4C;
    --ink-faint:  #8A8F7C;
    --moss:       #55654A;
    --moss-deep:  #38432E;
    --sage-tint:  #DEE3D0;
    --sage-line:  #C4CBB2;
    --plum:       #8A6E78;
    --gold:       #AC8A46;
    --rule:       #CDD1BE;
    --paper-edge: rgba(35,42,31,0.14);

    --font-display: "Fraunces", "Iowan Old Style", ui-serif, serif;
    --font-body: "Karla", -apple-system, "Segoe UI", sans-serif;
    --font-mono: "IBM Plex Mono", ui-monospace, monospace;
  }

  @page{ size:A4; margin:12mm 14mm; }

  *,*::before,*::after{ box-sizing:border-box; margin:0; padding:0; }

  html{ -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility; }

  body{
    font-family:var(--font-body);
    font-size:10.4pt;
    line-height:1.55;
    color:var(--ink);
    background:#DEDBCC;
  }

  .sheet{
    position:relative;
    max-width:216mm;
    margin:28px auto;
    background:var(--paper);
    box-shadow:0 1px 2px var(--paper-edge), 0 18px 40px -20px rgba(35,42,31,0.35);
  }
  .sheet::before{
    content:"";
    position:absolute; inset:0;
    pointer-events:none;
    opacity:0.5;
    mix-blend-mode:multiply;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='140' height='140'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='matrix' values='0 0 0 0 0.14  0 0 0 0 0.16  0 0 0 0 0.11  0 0 0 0.045 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
  }

  .tag-frame{
    position:relative;
    margin:34px 34px 0 34px;
    padding:26px 30px 22px;
    border:1px solid var(--rule);
  }
  .tag-frame::before,.tag-frame::after,
  .tag-frame .br-bl,.tag-frame .br-br{
    content:""; position:absolute; width:14px; height:14px;
  }
  .tag-frame::before{ top:-1px; left:-1px; border-top:2px solid var(--moss); border-left:2px solid var(--moss); }
  .tag-frame::after{ top:-1px; right:-1px; border-top:2px solid var(--moss); border-right:2px solid var(--moss); }
  .tag-frame .br-bl{ bottom:-1px; left:-1px; border-bottom:2px solid var(--moss); border-left:2px solid var(--moss); }
  .tag-frame .br-br{ bottom:-1px; right:-1px; border-bottom:2px solid var(--moss); border-right:2px solid var(--moss); }

  .eyebrow{
    font-family:var(--font-mono);
    font-size:7.6pt;
    letter-spacing:0.24em;
    text-transform:uppercase;
    color:var(--gold);
    margin-bottom:10px;
  }

  h1.name{
    font-family:var(--font-display);
    font-optical-sizing:auto;
    font-weight:500;
    font-style:italic;
    font-size:clamp(26pt,4.6vw,34pt);
    line-height:1.02;
    color:var(--moss-deep);
    letter-spacing:-0.01em;
  }

  .role-line{
    margin-top:6px;
    font-family:var(--font-body);
    font-weight:600;
    font-size:11pt;
    letter-spacing:0.02em;
    color:var(--ink-soft);
  }

  .headline{
    margin-top:10px;
    max-width:62ch;
    font-style:italic;
    font-size:9.6pt;
    color:var(--ink-soft);
  }

  .remote-tag{
    display:inline-block;
    margin-left:8px;
    padding:1px 8px;
    font-family:var(--font-mono);
    font-size:7pt;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--moss-deep);
    border:1px solid var(--sage-line);
    background:var(--sage-tint);
    vertical-align:middle;
  }

  .contact-row{
    display:flex; flex-wrap:wrap; gap:6px 20px;
    margin-top:16px;
    padding-top:14px;
    border-top:1px solid var(--rule);
  }
  .contact-item{
    display:inline-flex; align-items:center; gap:6px;
    font-size:9pt; color:var(--ink-soft);
  }
  .contact-item a{ color:var(--moss-deep); text-decoration:none; border-bottom:1px solid var(--sage-line); }
  .contact-item a:hover{ border-color:var(--moss-deep); }
  .contact-item svg{ width:12px; height:12px; stroke:var(--moss); flex-shrink:0; }

  .body-grid{
    display:grid;
    grid-template-columns:64mm 1fr;
    gap:0;
  }

  .sidebar{
    background:var(--sage-tint);
    padding:26px 26px 40px;
    border-right:1px solid var(--rule);
  }

  .avatar-frame{
    position:relative;
    width:88px; height:88px;
    margin-bottom:18px;
    border:1px solid var(--moss);
    padding:4px;
  }
  .avatar-frame img{ width:100%; height:100%; object-fit:cover; display:block; filter:saturate(0.86) sepia(0.06); }

  .side-h{
    display:flex; align-items:center; gap:6px;
    font-family:var(--font-mono);
    font-size:8pt;
    letter-spacing:0.16em;
    text-transform:uppercase;
    color:var(--moss-deep);
    margin:26px 0 12px;
  }
  .side-h:first-of-type{ margin-top:4px; }
  .side-h svg{ width:13px; height:13px; stroke:var(--gold); flex-shrink:0; }

  .skill-cluster{ margin-bottom:13px; }
  .skill-cluster h3{
    font-family:var(--font-body);
    font-weight:700;
    font-size:8.6pt;
    color:var(--moss-deep);
    margin-bottom:7px;
  }
  .skill-item{ margin-bottom:6px; }
  .skill-item-top{ display:flex; justify-content:space-between; font-size:8.4pt; color:var(--ink-soft); margin-bottom:3px; }
  .skill-bar{ height:3px; background:rgba(56,67,46,0.15); position:relative; overflow:hidden; }
  .skill-bar > span{ position:absolute; inset:0 auto 0 0; background:var(--moss); }

  .lang-item{ display:flex; justify-content:space-between; font-size:8.8pt; margin-bottom:5px; }
  .lang-item .lang-name{ font-weight:600; color:var(--ink); }
  .lang-item .lang-level{ font-family:var(--font-mono); font-size:7.4pt; color:var(--ink-faint); text-transform:uppercase; }

  .interest-tags{ display:flex; flex-wrap:wrap; gap:6px; }
  .interest-tag{
    font-size:7.8pt;
    padding:3px 8px;
    border:1px solid var(--sage-line);
    color:var(--moss-deep);
    font-family:var(--font-mono);
    letter-spacing:0.02em;
  }

  .sidebar-note{
    margin-top:26px; padding-top:16px; border-top:1px solid var(--sage-line);
    font-size:7.8pt; color:var(--ink-faint); font-style:italic;
  }

  .main{ padding:26px 32px 40px; }

  section{ margin-bottom:24px; }
  section:last-child{ margin-bottom:0; }

  .section-title{
    display:flex; align-items:center; gap:10px;
    font-family:var(--font-display);
    font-weight:600;
    font-style:italic;
    font-size:14pt;
    color:var(--moss-deep);
    margin-bottom:14px;
  }
  .section-title .sprig{ width:30px; height:14px; stroke:var(--gold); flex-shrink:0; }
  .section-title .rule{ flex:1; height:1px; background:var(--rule); }

  .summary-block p{
    font-size:10.6pt;
    color:var(--ink-soft);
  }
  .summary-block p::first-letter{
    font-family:var(--font-display);
    font-style:italic;
    font-weight:500;
    font-size:2.6em;
    float:left;
    line-height:0.82;
    padding:4px 6px 0 0;
    color:var(--moss-deep);
  }

  .entry-list{ position:relative; }
  .entry{
    position:relative;
    padding:0 0 18px 22px;
    border-left:1px solid var(--sage-line);
  }
  .entry:last-child{ padding-bottom:2px; }
  .entry::before{
    content:""; position:absolute; left:-4px; top:4px;
    width:7px; height:7px; border-radius:50%;
    background:var(--paper-soft); border:1.5px solid var(--moss);
  }

  .entry-head{ display:flex; justify-content:space-between; align-items:baseline; gap:12px; flex-wrap:wrap; }
  .entry-title{ font-weight:700; font-size:10.6pt; color:var(--ink); }
  .entry-dates{ font-family:var(--font-mono); font-size:7.8pt; letter-spacing:0.03em; color:var(--gold); white-space:nowrap; }
  .entry-org{ font-size:9.4pt; color:var(--moss-deep); font-weight:600; margin-top:1px; }
  .entry-org .loc{ color:var(--ink-faint); font-weight:400; }
  .entry-desc{ margin-top:6px; font-size:9.6pt; color:var(--ink-soft); }
  .entry ul{ margin-top:6px; padding-left:0; list-style:none; }
  .entry li{
    position:relative; padding-left:14px; margin-bottom:4px;
    font-size:9.6pt; color:var(--ink-soft);
  }
  .entry li::before{
    content:""; position:absolute; left:0; top:0.62em;
    width:5px; height:5px; background:var(--plum); transform:rotate(45deg);
  }

  .proj{ padding:12px 0; border-top:1px solid var(--rule); }
  .proj:first-child{ border-top:none; padding-top:0; }
  .proj-head{ display:flex; justify-content:space-between; align-items:baseline; gap:12px; flex-wrap:wrap; }
  .proj-name{ font-weight:700; font-size:10.4pt; color:var(--ink); }
  .proj-name .tagline{ font-weight:400; font-style:italic; color:var(--ink-soft); }
  .proj-year{ font-family:var(--font-mono); font-size:7.8pt; color:var(--gold); }
  .proj-desc{ margin-top:4px; font-size:9.5pt; color:var(--ink-soft); }
  .proj ul{ margin-top:6px; padding-left:0; list-style:none; }
  .proj li{ position:relative; padding-left:14px; margin-bottom:3px; font-size:9.4pt; color:var(--ink-soft); }
  .proj li::before{ content:""; position:absolute; left:0; top:0.62em; width:5px; height:5px; background:var(--plum); transform:rotate(45deg); }
  .stack-row{ margin-top:8px; display:flex; flex-wrap:wrap; gap:6px; }
  .stack-chip{
    font-family:var(--font-mono); font-size:7.4pt; letter-spacing:0.02em;
    padding:2px 7px; border:1px solid var(--sage-line); color:var(--moss-deep);
  }
  .proj-links{ margin-top:6px; display:flex; gap:14px; }
  .proj-links a{ font-size:8.4pt; color:var(--moss-deep); text-decoration:none; border-bottom:1px solid var(--sage-line); }

  .compact-item{
    display:flex; justify-content:space-between; align-items:baseline; gap:14px;
    padding:7px 0; border-top:1px solid var(--rule);
  }
  .compact-item:first-child{ border-top:none; padding-top:0; }
  .compact-main{ font-size:9.8pt; color:var(--ink); }
  .compact-main strong{ font-weight:700; }
  .compact-main a{ color:var(--moss-deep); }
  .compact-meta{ font-family:var(--font-mono); font-size:7.6pt; color:var(--ink-faint); white-space:nowrap; }
  .compact-desc{ margin-top:3px; font-size:9pt; color:var(--ink-soft); flex-basis:100%; }

  .testimonial{
    position:relative;
    padding:4px 0 4px 20px;
    margin-bottom:14px;
    border-left:2px solid var(--plum);
  }
  .testimonial:last-child{ margin-bottom:0; }
  .testimonial blockquote{ font-style:italic; font-size:9.8pt; color:var(--ink-soft); }
  .testimonial cite{ display:block; margin-top:6px; font-style:normal; font-family:var(--font-mono); font-size:7.6pt; letter-spacing:0.03em; text-transform:uppercase; color:var(--gold); }

  footer{
    padding:16px 32px 24px;
    border-top:1px solid var(--rule);
    font-size:7.6pt; color:var(--ink-faint);
    display:flex; justify-content:space-between; align-items:center;
  }
  footer a{ color:var(--moss-deep); text-decoration:none; }

  @media screen and (max-width:760px){
    .sheet{ margin:0; max-width:none; }
    .tag-frame{ margin:18px; padding:18px 18px 16px; }
    .body-grid{ grid-template-columns:1fr; }
    .sidebar{ border-right:none; border-bottom:1px solid var(--rule); }
    .main{ padding:22px 20px 30px; }
    footer{ flex-direction:column; align-items:flex-start; gap:4px; padding:16px 20px 20px; }
  }

  @media print{
    body{ background:#fff; }
    .sheet{ margin:0; max-width:none; box-shadow:none; }
    .sheet::before{ display:none; }
    * { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
    .entry{ break-inside:avoid; }
    .proj{ break-inside:avoid; }
    section{ break-inside:avoid; }
    .tag-frame{ margin:0 0 0 0; }
  }
</style>
</head>
<body>
<div class="sheet">

  <!-- ============================= HEADER ============================= -->
  <div class="tag-frame">
    <span class="br-bl"></span><span class="br-br"></span>
    {{#if title}}<div class="eyebrow">{{title}}</div>{{/if}}
    <h1 class="name">{{displayName}}</h1>
    {{#if headline}}<p class="headline">{{headline}}</p>{{/if}}

    <div class="contact-row">
      {{#if email}}
      <span class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="1"></rect><path d="M3 7l9 6 9-6"></path></svg>
        <a href="mailto:{{email}}">{{email}}</a>
      </span>
      {{/if}}
      {{#if phone}}
      <span class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.7a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2z"></path></svg>
        <span>{{phone}}</span>
      </span>
      {{/if}}
      {{#if locationStr}}
      <span class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <span>{{locationStr}}{{#if isRemote}}<span class="remote-tag">Remote</span>{{/if}}</span>
      </span>
      {{/if}}
      {{#if website}}
      <span class="contact-item">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"></path></svg>
        <a href="{{website}}">{{stripProtocol website}}</a>
      </span>
      {{/if}}
      {{#socialLinks}}
      <span class="contact-item">
        {{#if (eq key "github")}}
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"></path></svg>
        {{else if (eq key "linkedin")}}
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1.5"></rect><path d="M7 10v7M7 7v.01M12 17v-4.5a2 2 0 0 1 4 0V17M12 17v-7"></path></svg>
        {{else}}
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.5.5l2-2a5 5 0 0 0-7-7l-1.2 1.1"></path><path d="M14 11a5 5 0 0 0-7.5-.5l-2 2a5 5 0 0 0 7 7l1.1-1.1"></path></svg>
        {{/if}}
        <a href="{{url}}">{{label}}</a>
      </span>
      {{/socialLinks}}
    </div>
  </div>

  <!-- ============================== BODY =============================== -->
  <div class="body-grid">

    <!-- ------------------------------ SIDEBAR ------------------------------ -->
    <aside class="sidebar">

      {{#if photo}}
      <div class="avatar-frame"><img src="{{photo}}" alt="{{displayName}}"></div>
      {{/if}}

      {{#has skills}}
      <div class="side-h">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M12 2c-3 2-5 5-5 8s2 6 5 8c3-2 5-5 5-8s-2-6-5-8z"></path></svg>
        <span>Skills</span>
      </div>
      {{#skills}}
      <div class="skill-cluster">
        <h3>{{category}}</h3>
        {{#items}}
        <div class="skill-item">
          <div class="skill-item-top"><span>{{name}}</span></div>
          <div class="skill-bar"><span style="width:{{levelPercent level}}%"></span></div>
        </div>
        {{/items}}
      </div>
      {{/skills}}
      {{/has}}

      {{#has languages}}
      <div class="side-h">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"></path></svg>
        <span>Languages</span>
      </div>
      {{#languages}}
      <div class="lang-item">
        <span class="lang-name">{{language}}</span>
        <span class="lang-level">{{proficiency}}</span>
      </div>
      {{/languages}}
      {{/has}}

      {{#has interests}}
      <div class="side-h">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"></path></svg>
        <span>Interests</span>
      </div>
      <div class="interest-tags">
        {{#interests}}<span class="interest-tag">{{.}}</span>{{/interests}}
      </div>
      {{/has}}

      <div class="sidebar-note">Specimen record — updated {{year}}</div>
    </aside>

    <!-- -------------------------------- MAIN -------------------------------- -->
    <main class="main">

      {{#if summary}}
      <section class="summary-block">
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Profile</span><span class="rule"></span>
        </h2>
        <p>{{summary}}</p>
      </section>
      {{/if}}

      {{#has experience}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Experience</span><span class="rule"></span>
        </h2>
        <div class="entry-list">
          {{#experience}}
          <div class="entry">
            <div class="entry-head">
              <span class="entry-title">{{role}}</span>
              <span class="entry-dates">{{fmtDate startDate}} – {{fmtDate endDate}}</span>
            </div>
            <div class="entry-org">{{company}}{{#if location}} <span class="loc">· {{location}}</span>{{/if}}</div>
            {{#if description}}<p class="entry-desc">{{description}}</p>{{/if}}
            {{#has highlights}}
            <ul>{{#highlights}}<li>{{.}}</li>{{/highlights}}</ul>
            {{/has}}
          </div>
          {{/experience}}
        </div>
      </section>
      {{/has}}

      {{#has education}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Education</span><span class="rule"></span>
        </h2>
        <div class="entry-list">
          {{#education}}
          <div class="entry">
            <div class="entry-head">
              <span class="entry-title">{{degree}}{{#if field}} in {{field}}{{/if}}</span>
              <span class="entry-dates">{{fmtDate startDate}} – {{fmtDate endDate}}</span>
            </div>
            <div class="entry-org">{{institution}}{{#if gpa}} <span class="loc">· GPA {{gpa}}</span>{{/if}}</div>
            {{#has honors}}
            <ul>{{#honors}}<li>{{.}}</li>{{/honors}}</ul>
            {{/has}}
          </div>
          {{/education}}
        </div>
      </section>
      {{/has}}

      {{#has projects}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Projects</span><span class="rule"></span>
        </h2>
        {{#projects}}
        <div class="proj">
          <div class="proj-head">
            <span class="proj-name">{{name}}{{#if tagline}} <span class="tagline">— {{tagline}}</span>{{/if}}</span>
            {{#if year}}<span class="proj-year">{{year}}</span>{{/if}}
          </div>
          {{#if description}}<p class="proj-desc">{{description}}</p>{{/if}}
          {{#has highlights}}
          <ul>{{#highlights}}<li>{{.}}</li>{{/highlights}}</ul>
          {{/has}}
          {{#has techStack}}
          <div class="stack-row">{{#techStack}}<span class="stack-chip">{{.}}</span>{{/techStack}}</div>
          {{/has}}
          {{#if liveUrl}}{{#if repoUrl}}
          <div class="proj-links"><a href="{{liveUrl}}">Live</a><a href="{{repoUrl}}">Source</a></div>
          {{else}}
          <div class="proj-links"><a href="{{liveUrl}}">Live</a></div>
          {{/if}}{{else}}{{#if repoUrl}}
          <div class="proj-links"><a href="{{repoUrl}}">Source</a></div>
          {{/if}}{{/if}}
        </div>
        {{/projects}}
      </section>
      {{/has}}

      {{#has certifications}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Certifications</span><span class="rule"></span>
        </h2>
        {{#certifications}}
        <div class="compact-item">
          <span class="compact-main"><strong>{{name}}</strong> — {{issuer}}</span>
          <span class="compact-meta">{{fmtDate date}}</span>
        </div>
        {{/certifications}}
      </section>
      {{/has}}

      {{#has publications}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Publications</span><span class="rule"></span>
        </h2>
        {{#publications}}
        <div class="compact-item">
          <span class="compact-main">{{#if url}}<a href="{{url}}"><strong>{{title}}</strong></a>{{else}}<strong>{{title}}</strong>{{/if}} — {{publisher}}</span>
          <span class="compact-meta">{{fmtDate date}}</span>
        </div>
        {{/publications}}
      </section>
      {{/has}}

      {{#has awards}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Awards</span><span class="rule"></span>
        </h2>
        {{#awards}}
        <div class="compact-item">
          <span class="compact-main"><strong>{{title}}</strong> — {{issuer}}</span>
          <span class="compact-meta">{{fmtDate date}}</span>
          {{#if description}}<span class="compact-desc">{{description}}</span>{{/if}}
        </div>
        {{/awards}}
      </section>
      {{/has}}

      {{#has volunteer}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Volunteer</span><span class="rule"></span>
        </h2>
        <div class="entry-list">
          {{#volunteer}}
          <div class="entry">
            <div class="entry-head">
              <span class="entry-title">{{role}}</span>
              <span class="entry-dates">{{fmtDate startDate}} – {{fmtDate endDate}}</span>
            </div>
            <div class="entry-org">{{organization}}</div>
            {{#if description}}<p class="entry-desc">{{description}}</p>{{/if}}
          </div>
          {{/volunteer}}
        </div>
      </section>
      {{/has}}

      {{#has testimonials}}
      <section>
        <h2 class="section-title">
          <svg class="sprig" viewBox="0 0 32 16" fill="none" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M1 8h30"></path><path d="M9 8c0-3 2-5 4-5M9 8c0 3 2 5 4 5M23 8c0-3-2-5-4-5M23 8c0 3-2 5-4 5"></path><circle cx="16" cy="8" r="1.6" fill="currentColor" stroke="none"></circle></svg>
          <span>Testimonials</span><span class="rule"></span>
        </h2>
        {{#testimonials}}
        <div class="testimonial">
          <blockquote>"{{quote}}"</blockquote>
          {{author}}{{#if role}}, {{role}}{{/if}}{{#if company}} · {{company}}{{/if}}
        </div>
        {{/testimonials}}
      </section>
      {{/has}}

    </main>
  </div>

  <footer>
    <span>Herbarium — a specimen-record resume theme</span>
    <span>Built with <a href="{{toolsUrl}}">One File Tools</a></span>
  </footer>

</div>
</body>
</html>